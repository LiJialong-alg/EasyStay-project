/**
 * 酒店列表页 - 携程蓝简约版
 */
 page {
  --primary-blue: #0086F6;
  --bg-color: #F4F6F9;
  --text-main: #333333;
  --text-sub: #666666;
  --text-light: #999999;
  --header-height: 200rpx; /* 搜索栏+筛选栏的总高度预估 */
  
  background-color: var(--bg-color);
  height: 100vh;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
}

view, text, scroll-view, input {
  box-sizing: border-box;
}

.page-list {
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* --- 顶部固定区域 --- */
.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  background-color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 1. 蓝色搜索区 */
.search-header {
  background-color: var(--primary-blue);
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  /* 适配不同机型的高度 */
  height: 100rpx; 
}

/* 搜索胶囊 */
.search-capsule {
  flex: 1;
  background-color: #fff;
  border-radius: 8rpx; /* 稍微方一点的圆角，更显专业 */
  height: 68rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}

/* 胶囊左侧：城市日期 */
.capsule-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-right: 12rpx;
  min-width: 100rpx;
  max-width: 180rpx; /* 限制宽度 */
}

.city-text {
  text-align: center;
  font-size: 24rpx;
  font-weight: bold;
  color: var(--text-main);
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.date-text {
  font-size: 18rpx;
  color: var(--primary-blue);
  line-height: 1.2;
  display: flex;
  justify-content: space-between;
}

.triangle-icon {
  display: none; /* 空间不够时可以隐藏，或者做成极小的角标 */
}

/* 分割线 */
.capsule-divider {
  width: 1px;
  height: 32rpx;
  background-color: #eee;
  margin: 0 12rpx;
}

/* 胶囊中间：输入框 */
.capsule-middle {
  flex: 1;
  display: flex;
  align-items: center;
}

.capsule-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-main);
  margin-left: 10rpx;
  height: 68rpx;
}

.input-placeholder {
  color: #ccc;
  font-size: 26rpx;
}

/* 右侧搜索按钮文字 */
.header-search-btn {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  margin-left: 20rpx;
  padding: 10rpx 0;
}

/* 2. 筛选条 */
.filter-bar {
  background-color: #fff;
  height: 80rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.filter-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 26rpx;
  color: var(--text-main);
  height: 100%;
  position: relative;
}
.filter-item2{
  /* flex:2 */
  flex: 1.2;
  margin-top: 3rpx;
}

.filter-icon {
  font-size: 18rpx;
  margin-left: 6rpx;
  color: #ccc;
}

/* 选中状态 */
.filter-item.active {
  color: var(--primary-blue);
  font-weight: bold;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 4rpx;
  background-color: var(--primary-blue);
  border-radius: 4rpx;
}

/* --- 列表滚动区 --- */
.hotel-list-scroll {
  padding-top: 180rpx; /* 留出头部高度 (100 + 80) */
  height: 100vh;
}

.hotel-list-content {
  padding: 20rpx 24rpx;
}

.list-item-wrapper {
  margin-bottom: 24rpx;
}

/* --- 底部状态 --- */
.footer-status {
  padding: 30rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading-more, .no-more, .empty-state {
  font-size: 24rpx;
  color: var(--text-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.spinner {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid var(--primary-blue);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 12rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.empty-state {
  flex-direction: column;
  padding-top: 100rpx;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* --- 骨架屏 (简化版) --- */
.skeleton-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeleton-card {
  width: 100%;
  height: 280rpx;
  background-color: #fff;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}

.skeleton-card::after {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  100% { left: 100%; }
}