/* 变量定义：携程色系 */
page {
  --ctrip-blue: #0086F6;
  --ctrip-orange: #FF6600;
  --bg-color: #F5F7FA;
  --text-main: #333333;
  --text-sub: #666666;
  --text-light: #999999;
}

.detail-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 1. 图片轮播 */
.banner-wrapper {
  width: 100%;
  height: 360rpx; /* 适当的高度 */
  position: relative;
  background-color: #eee;
}

.banner {
  width: 100%;
  height: 100%;
}

.banner image {
  width: 100%;
  height: 100%;
  display: block; /* 消除图片底部缝隙 */
}

.banner-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0,0,0,0) 70%, rgba(0,0,0,0.5) 100%);
  pointer-events: none; /* 让点击穿透遮罩 */
}

/* 2. 核心内容容器 - 向上浮动重叠 */
.content-wrapper {
  position: relative;
  top: -20rpx; /* 向上偏移 */
  padding: 0 20rpx;
  z-index: 20;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

/* 头部信息卡片 */
.hotel-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.hotel-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-right: 12rpx;
}

.star-badge {
  font-size: 20rpx;
  color: var(--text-sub);
  border: 1px solid #ddd;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.hotel-en-name {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 20rpx;
}

.score-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.score-box {
  display: flex;
  align-items: baseline;
}

.score-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--ctrip-blue);
  margin-right: 10rpx;
}

.score-text {
  font-size: 28rpx;
  color: var(--ctrip-blue);
  font-weight: 600;
}

.review-link {
  font-size: 24rpx;
  color: var(--text-sub);
}

.location-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.loc-left {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.address-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 4rpx;
}

.loc-desc {
  font-size: 22rpx;
  color: var(--text-light);
}

.loc-icon-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
  color: var(--ctrip-blue);
}

.loc-icon-box .icon { font-size: 32rpx; margin-bottom: 4rpx; }
.loc-icon-box .icon-text { font-size: 20rpx; }

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.facility-tag {
  background-color: #F0F8FF; /* 浅蓝背景 */
  color: #0066CC;
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
}

/* 3. 日期选择 */
.date-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-block {
  display: flex;
  flex-direction: column;
}

.d-label { font-size: 22rpx; color: var(--text-light); margin-bottom: 4rpx;
margin-left: 60rpx;}
.d-date { font-size: 32rpx; font-weight: 700; color: var(--text-main); }

.date-duration {
  flex: 1;
  display: flex;
  justify-content: center;
}

.duration-badge {
  border: 1px solid #0086F6;
  border-radius: 20rpx;
  padding: 2rpx 16rpx;
  font-size: 20rpx;
  color: var(--text-main);
}

.date-arrow { color: #ccc; font-weight: bold;}

/* 4. 房型列表 */
.room-section {
  margin-bottom: 20rpx;
}

.room-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.room-card.active {
  border-color: var(--ctrip-blue);
  background-color: #F8FBFF;
}

.room-img-placeholder {
  width: 140rpx;
  height: 140rpx;
  background-color: #eee;
  border-radius: 10rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.room-img{
  width: 100%;
  height: 100%;
  display: block;
}

.room-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.r-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.r-tags {
  width: 80%;
  display: flex;
  flex-wrap: wrap;
  /* gap: 8rpx; */
  /* margin-top: 8rpx; */
  flex-direction: column;
}

.r-tag {
  margin-right: 10rpx;
  font-size: 20rpx;
  color: var(--ctrip-blue);
  border: 1px solid rgba(0, 134, 246, 0.3);
  padding: 0 6rpx;
  border-radius: 4rpx;
  white-space: nowrap; 
}

.r-stock {
  font-size: 20rpx;
  color: #666;
  margin-top: 8rpx;
}

.room-action {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  min-width: 140rpx;
}

.r-price {
  color: var(--ctrip-orange);
  font-weight: 700;
  margin-bottom: 12rpx;
}
.discount{
  color: #c0c0c0;
  font-weight: 700;
  margin-bottom: 12rpx;
  text-decoration: line-through;
}
.r-price .currency { font-size: 24rpx; }
.r-price .amount { font-size: 40rpx; }

.book-btn-look {
  width: 100rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  background: linear-gradient(90deg, #FFA033 0%, #FF6600 100%);
  color: white;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

.book-btn-look.selected {
  background: none;
  border: 1px solid var(--ctrip-blue);
  color: var(--ctrip-blue);
  background-color: white;
}

/* 5. 评价 */
.section-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-header .title { font-size: 30rpx; font-weight: 700; }
.section-header .more { font-size: 24rpx; color: var(--ctrip-blue); }

.review-item {
  background: #f9f9f9;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.r-user {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.avatar {
  width: 40rpx;
  height: 40rpx;
  background: #ddd;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 20rpx;
  color: #fff;
  margin-right: 12rpx;
}
.u-info { flex: 1; display: flex; }
.u-info .name { font-size: 24rpx; font-weight: bold; }
.u-info .score { font-size: 20rpx; color: var(--ctrip-blue); margin-top: 5rpx; 
margin-left: 15rpx;}
.r-date { font-size: 20rpx; color: var(--text-light); }
.r-content { font-size: 26rpx; color: var(--text-sub); line-height: 1.4; }

/* 6. 底部悬浮栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.bar-left {
  display: flex;
  flex-direction: column;
}

.tips { font-size: 28rpx; color: var(--text-light); }

.total-price-box {
  display: flex;
  align-items: baseline;
  color: var(--ctrip-orange);
}
.total-label { font-size: 24rpx; margin-right: 8rpx; color: var(--text-main);}
.total-currency { font-size: 24rpx; font-weight: bold; }
.total-amount { font-size: 44rpx; font-weight: bold; }

.room-desc { font-size: 20rpx; color: var(--text-sub); }

.bar-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 数量控制器 - 小巧版 */
.qty-control {
  display: flex;
  align-items: center;
  border: 1px solid #eee;
  border-radius: 6rpx;
  height: 50rpx;
}

.q-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--ctrip-blue);
  background: #f5f5f5;
}
.q-btn:active { background: #e0e0e0; }
.q-num {
  width: 50rpx;
  text-align: center;
  font-size: 24rpx;
}

.submit-btn {
  width: 300rpx !important;
  background: linear-gradient(90deg, #FFA033 0%, #FF6600 100%);
  color: white;
  font-size: 30rpx;
  font-weight: bold;
  padding: 0 40rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  margin: 0;
}

.submit-btn.disabled {
  background: #ccc;
  color: #fff;
}

