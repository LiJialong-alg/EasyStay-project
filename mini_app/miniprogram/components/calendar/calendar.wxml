
<view class="calendar-component">
  <view class="calendar-header">
    <text class="calendar-title">选择日期</text>
    <view class="close-btn" bindtap="onClose">确定并返回</view>
  </view>

  <scroll-view scroll-y class="months-container">
    <view wx:for="{{ monthList }}" wx:for-item="monthItem" wx:key="monthStr" class="month-section">
      <view class="month-title">{{ monthItem.year }}年{{ monthItem.month }}月</view>
      
      <view class="weekdays">
        <view class="weekday" wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this">{{item}}</view>
      </view>

      <view class="days-grid">
        <view wx:for="{{ monthItem.startIndex }}" wx:key="index" class="day-item-empty"></view>
        
        <view
          wx:for="{{ monthItem.dates }}"
          wx:key="date"
          class="day-item {{ item.status === -1 ? 'disabled' : '' }} {{ item.status > 0   ? 'selected' : '' }} {{ item.status === 3 ? 'in-range' : '' }}"
          data-date="{{ item.date }}"
          data-month="{{monthItem.month}}"
          bindtap="onDateTap"
        >
          <text>{{ item.date }}</text>
          <text class="in-out" wx:if="{{item.status === 1}}">{{'入住'}}</text>
          <text class="in-out" wx:if="{{item.status === 2}}">{{'离店'}}</text>

        </view>
      </view>
    </view>
  </scroll-view>
</view>